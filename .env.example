# Ganglion Configuration
# Copy this file to .env and fill in the values.

# ── LLM ──────────────────────────────────────────────────
# Required: API key for LLM provider (OpenAI, Chutes, or compatible)
LLM_PROVIDER_API_KEY=
# Optional: Custom base URL for OpenAI-compatible APIs
LLM_PROVIDER_BASE_URL=
# LLM model to use (default: gpt-4o)
GANGLION_LLM_MODEL=gpt-4o
# Retry settings for LLM calls
GANGLION_LLM_MAX_RETRIES=5
GANGLION_LLM_BASE_DELAY=1.0
GANGLION_LLM_MAX_DELAY=60.0
GANGLION_LLM_REQUEST_TIMEOUT=120.0

# ── Named LLM Backends (optional) ────────────────────────
# JSON object mapping backend names to their configs.
# Each backend can have: api_key, base_url, model, max_retries, base_delay, max_delay, request_timeout
# A "default" backend is always created from the LLM_PROVIDER_* vars above.
# Claw bot can assign backends to pipeline stages by name (no keys exposed).
# GANGLION_LLM_BACKENDS='{"fast":{"api_key":"sk-...","model":"gpt-4o-mini"},"reasoning":{"api_key":"sk-ant-...","base_url":"https://api.anthropic.com/v1","model":"claude-sonnet-4-6"}}'

# ── Server ───────────────────────────────────────────────
# Host and port for the HTTP bridge
GANGLION_HOST=127.0.0.1
GANGLION_PORT=8899

# ── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins (no wildcard in production)
GANGLION_CORS_ORIGINS=http://localhost:3000

# ── Rate Limiting ────────────────────────────────────────
# Maximum requests per minute per client
GANGLION_RATE_LIMIT_RPM=60

# ── Logging ──────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
GANGLION_LOG_LEVEL=INFO
# Log format: json or text
GANGLION_LOG_FORMAT=json

# ── Knowledge Store ──────────────────────────────────────
GANGLION_MAX_PATTERNS=500
GANGLION_MAX_ANTIPATTERNS=500

# ── Request Limits ───────────────────────────────────────
# Max request body size in bytes (default: 10MB)
GANGLION_MAX_REQUEST_BODY_BYTES=10485760
